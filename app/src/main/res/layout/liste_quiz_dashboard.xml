<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout d'un item de quiz affiché sur le tableau de bord.
    Design similaire aux cartes de cours/travaux avec
    le code du cours, le titre du quiz et une flèche.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Code du cours associé au quiz -->
            <TextView
                android:id="@+id/tvQuizCoursCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TCH057"
                android:textSize="12sp"
                android:textColor="@color/orange" />

            <!-- Titre du quiz -->
            <TextView
                android:id="@+id/tvQuizTitre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz du cours #10"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <!-- Statut ou info supplémentaire -->
            <TextView
                android:id="@+id/tvQuizInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expire dans ..."
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/orange"
            android:contentDescription="Voir quiz" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
