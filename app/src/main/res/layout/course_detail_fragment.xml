<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout de l'écran Détails d'un Cours.
    Affiche les informations complètes d'un cours sélectionné :
    - En-tête avec code, titre et enseignant
    - Description du cours
    - Section Annonces
    - Section Travaux (avec RecyclerView)
    - Section Quiz

    Utilise un ScrollView pour permettre le défilement
    quand le contenu est plus long que l'écran.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== BOUTON RETOUR ===== -->
        <!--
            Permet de revenir à la liste des cours.
            Utilise le FragmentManager pour dépiler (popBackStack).
        -->
        <LinearLayout
            android:id="@+id/btnRetour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:padding="4dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/orange" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retour"
                android:textColor="@color/orange"
                android:textSize="14sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- ===== EN-TÊTE DU COURS ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Code du cours (ex: TCH057) -->
                <TextView
                    android:id="@+id/tvDetailCodeCours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TCH057"
                    android:textColor="@color/orange"
                    android:textSize="14sp" />

                <!-- Titre du cours -->
                <TextView
                    android:id="@+id/tvDetailTitreCours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Développement mobile"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="4dp" />

                <!-- Nom de l'enseignant -->
                <TextView
                    android:id="@+id/tvDetailEnseignant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enseignant : ---"
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:layout_marginTop="4dp" />

                <!-- Session (ex: H2026) -->
                <TextView
                    android:id="@+id/tvDetailSession"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Session : ---"
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:layout_marginTop="2dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== DESCRIPTION DU COURS ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/orange"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Description du cours..."
                    android:textSize="14sp"
                    android:textColor="@color/black" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== ANNONCES ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Annonces"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/orange"
                    android:layout_marginBottom="6dp" />

                <!--
                    Container dynamique pour les annonces.
                    Les annonces sont ajoutées par programmation
                    car leur nombre varie selon le cours.
                -->
                <LinearLayout
                    android:id="@+id/llAnnonces"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Affiché quand il n'y a aucune annonce -->
                <TextView
                    android:id="@+id/tvAucuneAnnonce"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aucune annonce."
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== TRAVAUX DU COURS ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Travaux"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/orange"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDetailTravaux"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="16dp" />

        <!-- Affiché quand il n'y a aucun travail pour ce cours -->
        <TextView
            android:id="@+id/tvAucunTravail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aucun travail pour ce cours."
            android:textSize="14sp"
            android:textColor="@color/gray"
            android:textAlignment="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
