<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout de l'écran Détails d'un Travail.
    Affiche les informations complètes du travail :
    - Titre, description, consignes
    - Date limite et statut
    - Note et commentaire (si corrigé)
    - Bouton de soumission simulée
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Bouton retour -->
        <LinearLayout
            android:id="@+id/btnRetourDevoir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:padding="4dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/orange" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retour"
                android:textColor="@color/orange"
                android:textSize="14sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- ===== EN-TÊTE DU TRAVAIL ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDetailTitreDevoir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Titre du travail"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />

                <TextView
                    android:id="@+id/tvDetailStatutDevoir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Statut : À faire"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvDetailDateLimite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date limite : ---"
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvDetailPointsDevoir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Points : --- / ---"
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== DESCRIPTION & CONSIGNES ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/orange"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvDetailDescDevoir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Description du travail..."
                    android:textSize="14sp"
                    android:textColor="@color/black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Consignes"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/orange"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvDetailInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Consignes du travail..."
                    android:textSize="14sp"
                    android:textColor="@color/black" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== NOTE ET COMMENTAIRE (visible seulement si corrigé) ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Note et commentaire"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/orange"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvDetailNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Note : ---"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />

                <TextView
                    android:id="@+id/tvDetailCommentaire"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aucun commentaire."
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== SOUMISSION SIMULÉE ===== -->
        <!--
            Section de soumission simulée :
            - Champ pour saisir un URL ou un texte de réponse
            - Bouton "Marquer comme remis"
            Visible seulement si le travail n'est pas encore remis.
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSoumission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Soumission"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/orange"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etSoumissionUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Collez un lien URL ou saisissez votre réponse..."
                    android:inputType="text"
                    android:minHeight="48dp"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnMarquerRemis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Marquer comme remis"
                    android:background="@drawable/button_template"
                    app:backgroundTint="@color/orange" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
