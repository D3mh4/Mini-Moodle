<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mes Cours"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="12dp" />
    <EditText
        android:id="@+id/etRechercheCours"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/button_template"
        android:backgroundTint="@color/white"
        android:drawableStart="?android:attr/actionModeWebSearchDrawable"
        android:drawablePadding="8dp"
        android:hint="Rechercher un cours..."
        android:inputType="text"
        android:padding="12dp"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvListeCours"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tvAucunCours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aucun cours trouvé."
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="@color/gray"
        android:visibility="gone"
        android:layout_marginTop="40dp" />

</LinearLayout>
