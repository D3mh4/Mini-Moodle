<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout de l'écran principal des Travaux.
    Affiche tous les travaux de l'utilisateur avec leur statut.
    Permet un suivi global de l'avancement des travaux.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="16dp">

    <!-- Titre de l'écran -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mes Travaux"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="6dp" />

    <!-- ===== RÉSUMÉ DES STATUTS ===== -->
    <!--
        Carte affichant le nombre de travaux par statut.
        Donne une vue d'ensemble rapide à l'étudiant.
    -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/white"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center">

            <!-- Compteur "À faire" -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvCountAFaire"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/orange" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="À faire"
                    android:textSize="11sp"
                    android:textColor="@color/gray" />
            </LinearLayout>

            <!-- Compteur "Remis" -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvCountRemis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remis"
                    android:textSize="11sp"
                    android:textColor="@color/gray" />
            </LinearLayout>

            <!-- Compteur "En retard" -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvCountRetard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#F44336" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="En retard"
                    android:textSize="11sp"
                    android:textColor="@color/gray" />
            </LinearLayout>

            <!-- Compteur "Corrigé" -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvCountCorrige"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Corrigé"
                    android:textSize="11sp"
                    android:textColor="@color/gray" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ===== LISTE DES TRAVAUX ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTousLesTravaux"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Message si aucun travail -->
    <TextView
        android:id="@+id/tvAucunDevoir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aucun travail trouvé."
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="@color/gray"
        android:visibility="gone"
        android:layout_marginTop="40dp" />

</LinearLayout>
